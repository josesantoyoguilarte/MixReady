    async function autoAnalyze(entry, card) {
        card.querySelector('.track-detected-bpm').textContent = '...';
        card.querySelector('.track-detected-key').textContent = '...';
        card.querySelector('.track-detected-genre').textContent = '...';
        try {
            const res = await fetch(`${API_K}/${entry.trackId}/analyze`, { method: 'POST' });
            if (!res.ok) throw new Error();
            const data = await res.json();
            card.querySelector('.track-detected-bpm').textContent = data.bpm ? Math.round(data.bpm) : '--';
            card.querySelector('.track-detected-key').textContent = data.key || '--';
            card.querySelector('.track-detected-genre').textContent = data.genre || '--';
            entry.bars = data.bars || [];
            // Draw bar markers
            if (entry.ws && entry.bars.length) {
                const draw = () => {
                    const w = entry.ws.getWrapper(); if(!w) return;
                    const dur = entry.ws.getDuration(); if(!dur) return;
                    const ruler = card.querySelector('.track-bar-ruler');
                    drawBarGrid(w, entry.bars, dur, 'main', ruler);
                };
                if(entry.ws.getDuration()) draw(); else entry.ws.on('ready', draw);
            }
        } catch {
            card.querySelector('.track-detected-bpm').textContent = '?';
            card.querySelector('.track-detected-key').textContent = '?';
            card.querySelector('.track-detected-genre').textContent = '?';
        }
    }

    const STEM_COLORS = { drums:'#e74c3c', bass:'#3498db', other:'#2ecc71', vocals:'#9b59b6' };

    // --- Shared bar-grid renderer -------------------------------------------------
    // variant: 'main' (taller waveform, labels every 4 bars) or 'stem' (compact)
    // ruler: optional external strip where bar numbers are rendered (so they don't
    //        overlap the waveform). When provided, the wrapper only gets line markers.
    function drawBarGrid(wrapper, bars, duration, variant, ruler) {
        if (!wrapper || !bars || !bars.length || !duration) return;
        wrapper.style.position = 'relative';
        if (variant === 'main') wrapper.style.overflow = 'visible';
        wrapper.querySelectorAll('.bar-marker,.beat-marker,.bar-number').forEach(m => m.remove());
        if (ruler) {
            ruler.style.position = 'relative';
            ruler.querySelectorAll('.bar-number,.bar-tick').forEach(m => m.remove());
        }

        const isMain = variant === 'main';
        // Colors / widths chosen so they stay legible over cyan / red / blue / green / purple.
        // Downbeats use bright white (was amber) for cleaner readability.
        const downbeatColor = isMain ? 'rgba(255,255,255,0.85)' : 'rgba(255,255,255,0.70)';
        const barColor      = isMain ? 'rgba(255,255,255,0.40)' : 'rgba(255,255,255,0.25)';
        const beatColor     = 'rgba(255,255,255,0.08)';
        const downbeatW     = isMain ? 2 : 1.5;
        const labelEvery    = isMain ? 4 : 8;

        bars.forEach((bar, i) => {
            const barStart = bar[0];
            const barEnd   = bar[1] ?? (bars[i+1] ? bars[i+1][0] : barStart + (bar[0] - (bars[i-1]?.[0] ?? 0)));
            const isDownbeat = (i % 4 === 0);

            // Main bar line
            const pct = (barStart / duration) * 100;
            const mk = document.createElement('div');
            mk.className = 'bar-marker';
            mk.style.cssText =
                `position:absolute;left:${pct}%;top:0;height:100%;` +
                `width:${isDownbeat ? downbeatW : 1}px;` +
                `background:${isDownbeat ? downbeatColor : barColor};` +
                `pointer-events:none;z-index:4;`;
            wrapper.appendChild(mk);

            // 3 beat subdivisions inside this bar (skip when bars are too small visually)
            const barWidthPct = ((barEnd - barStart) / duration) * 100;
            if (barWidthPct > 0.8) {
                for (let b = 1; b <= 3; b++) {
                    const tBeat = barStart + ((barEnd - barStart) * b / 4);
                    const bp = (tBeat / duration) * 100;
                    const bm = document.createElement('div');
                    bm.className = 'beat-marker';
                    bm.style.cssText =
                        `position:absolute;left:${bp}%;top:25%;height:50%;width:1px;` +
                        `background:${beatColor};` +
                        `pointer-events:none;z-index:3;` +
                        `border-left:1px dotted ${beatColor};`;
                    wrapper.appendChild(bm);
                }
            }

            // Bar number label (placed in external ruler if provided, otherwise over the waveform)
            if (i % labelEvery === 0) {
                const lb = document.createElement('span');
                lb.className = 'bar-number';
                // Numeric-only labels on both main and stem rulers.
                lb.textContent = (i + 1);

                if (ruler) {
                    // Render into dedicated ruler strip -- never overlaps the waveform.
                    // Also add a small downward tick that points at the bar line.
                    lb.style.cssText =
                        'position:absolute;bottom:0;transform:translateX(-50%);' +
                        (isMain ? 'font-size:10px;' : 'font-size:8px;') +
                        'font-weight:700;color:#ffffff;' +
                        'background:rgba(0,0,0,0.7);padding:0 4px;border-radius:3px;' +
                        'border:1px solid rgba(255,255,255,0.35);pointer-events:none;white-space:nowrap;' +
                        'line-height:1.1;' +
                        `left:${pct}%;`;
                    ruler.appendChild(lb);

                    const tick = document.createElement('div');
                    tick.className = 'bar-tick';
                    tick.style.cssText =
                        `position:absolute;left:${pct}%;bottom:-2px;width:1px;height:3px;` +
                        `background:${downbeatColor};pointer-events:none;`;
                    ruler.appendChild(tick);
                } else if (isMain) {
                    // Fallback: floated above wrapper (legacy path, kept for safety)
                    lb.style.cssText =
                        'position:absolute;top:-14px;transform:translateX(-50%);' +
                        'font-size:10px;font-weight:700;color:#ffffff;' +
                        'background:rgba(0,0,0,0.65);padding:1px 5px;border-radius:3px;' +
                        'border:1px solid rgba(255,255,255,0.35);pointer-events:none;white-space:nowrap;' +
                        `left:${pct}%;`;
                    wrapper.appendChild(lb);
                } else {
                    lb.style.cssText =
                        'position:absolute;bottom:1px;transform:translateX(-50%);' +
                        'font-size:8px;font-weight:600;color:#ffffff;' +
                        'background:rgba(0,0,0,0.55);padding:0 3px;border-radius:2px;' +
                        'pointer-events:none;white-space:nowrap;' +
                        `left:${pct}%;`;
                    wrapper.appendChild(lb);
                }
            }
        });
    }
    // -----------------------------------------------------------------------------

    async function autoSeparateStems(entry, card) {
        const area = card.querySelector('.track-stems-area');
        area.classList.remove('d-none');
        const status = card.querySelector('.track-stems-status');
        status.style.color = '#ffc107';
        status.textContent = 'AI is separating stems...';
        card.querySelector('.track-stems').classList.add('d-none');
        entry.stemWs = {};

        try {
            await fetch(`${API_K}/${entry.trackId}/separate`, { method: 'POST' });
            const poll = setInterval(async () => {
                const res = await fetch(`${API_K}/${entry.trackId}/stems-status`);
                const data = await res.json();
                if (data.ready) {
                    clearInterval(poll);
                    status.style.color = '#4caf50';
                    status.textContent = 'All stems detected -- select which to use for intro';
                    card.querySelector('.track-stems').classList.remove('d-none');
                    initIntroStemWaveforms(entry, card);
                } else if (data.error) {
                    clearInterval(poll);
                    status.style.color = '#f44336';
                    status.textContent = 'Error: ' + data.error;
                }
            }, 3000);
        } catch (err) {
            status.style.color = '#f44336';
            status.textContent = err.message;
        }
    }

    function initIntroStemWaveforms(entry, card) {
        const tid = entry.trackId;
        ['drums', 'bass', 'other', 'vocals'].forEach(stem => {
            const container = card.querySelector(`.track-stem-wf[data-stem="${stem}"]`);
            if (!container) return;
            const ws = WaveSurfer.create({
                container,
                url: `${API_K}/${tid}/stem/${stem}`,
                waveColor: STEM_COLORS[stem],
                progressColor: STEM_COLORS[stem] + '44',
                cursorColor: '#fff8',
                height: 35, barWidth: 2, barGap: 1, barRadius: 1,
            });
            ws.on('interaction', () => ws.playPause());
            entry.stemWs[stem] = ws;
            // Draw bar markers on stems too
            if (entry.bars && entry.bars.length) {
                const draw = () => {
                    const w = ws.getWrapper(); if(!w) return;
                    const dur = ws.getDuration(); if(!dur) return;
                    const ruler = card.querySelector(`.track-stem-ruler[data-stem="${stem}"]`);
                    drawBarGrid(w, entry.bars, dur, 'stem', ruler);
                };
                if(ws.getDuration()) draw(); else ws.on('ready', draw);
            }

            // Redraw region on this stem once it loads (if region was selected before stems ready)
            ws.on('ready', () => {
                if (entry.region && entry.region.start != null && entry.region.end != null) {
                    drawRegionOverlay(container, entry.region.start, entry.region.end, ws.getDuration(), false);
                }
            });
        });

        // Wire play buttons
        card.querySelectorAll('.stem-play-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const stem = btn.dataset.stem;
                const ws = entry.stemWs[stem];
                if (!ws) return;
                // Pause others
                ['drums','bass','other','vocals'].forEach(s => { if(s!==stem && entry.stemWs[s]) entry.stemWs[s].pause(); });
                card.querySelectorAll('.stem-play-btn').forEach(b => { b.classList.remove('playing'); b.innerHTML='&#9654;'; });
                if (ws.isPlaying()) { ws.pause(); btn.innerHTML='&#9654;'; }
                else { ws.play(); btn.innerHTML='&#9646;&#9646;'; btn.classList.add('playing'); ws.on('finish',()=>{btn.innerHTML='&#9654;';btn.classList.remove('playing');}); }
            });
        });
    }

    // --- Intro preview: play selected stems together over [region.start, region.end] ---
    function setupIntroPreview(entry, card) {
        const btn = card.querySelector('.btn-preview-intro');
        if (!btn || btn.dataset.wired === '1') return;
        btn.dataset.wired = '1';
        entry._introPreviewPlaying = false;

        const stopPreview = () => {
            entry._introPreviewPlaying = false;
            if (entry._introPreviewTimer) { clearInterval(entry._introPreviewTimer); entry._introPreviewTimer = null; }
            if (entry.stemWs) {
                ['drums','bass','other','vocals'].forEach(s => {
                    const w = entry.stemWs[s];
                    if (w && w.isPlaying()) w.pause();
                });
            }
            btn.innerHTML = '&#9654;';
            btn.classList.remove('playing');
        };

        btn.addEventListener('click', () => {
            if (entry._introPreviewPlaying) { stopPreview(); return; }

            const s = entry.region?.start;
            const e = entry.region?.end;
            if (s == null || e == null || e <= s) {
                alert('Select an intro region first: click on the main waveform for START, Shift+Click for END.');
                return;
            }
            if (!entry.stemWs || Object.keys(entry.stemWs).length === 0) {
                alert('Stems are still being separated. Please wait until they appear.');
                return;
            }
            // Pause any solo-stem playback
            card.querySelectorAll('.stem-play-btn').forEach(b => { b.classList.remove('playing'); b.innerHTML = '&#9654;'; });

            // Selected stems (from the checkboxes)
            const selected = [];
            card.querySelectorAll('.track-stem-check:checked').forEach(cb => selected.push(cb.dataset.stem));
            if (selected.length === 0) {
                alert('Select at least one stem checkbox to preview the intro.');
                return;
            }
            const loop = card.querySelector('.track-intro-preview-loop')?.checked;

            // Seek every selected stem to the region start and play together
            const startFraction = (ws) => {
                const d = ws.getDuration();
                return d > 0 ? Math.min(0.999, s / d) : 0;
            };
            selected.forEach(stem => {
                const ws = entry.stemWs[stem];
                if (!ws) return;
                try { ws.seekTo(startFraction(ws)); ws.play(); } catch {}
            });
            entry._introPreviewPlaying = true;
            btn.innerHTML = '&#9632;';
            btn.classList.add('playing');

            // Watch for the end of the region; loop or stop
            entry._introPreviewTimer = setInterval(() => {
                const first = entry.stemWs[selected[0]];
                if (!first) { stopPreview(); return; }
                const t = first.getCurrentTime();
                if (t >= e) {
                    if (loop) {
                        selected.forEach(stem => {
                            const ws = entry.stemWs[stem];
                            if (ws) { try { ws.seekTo(startFraction(ws)); ws.play(); } catch {} }
                        });
                    } else {
                        stopPreview();
                    }
                }
            }, 60);
        });

        // Re-sync if user toggles a stem checkbox while preview is playing
        card.querySelectorAll('.track-stem-check').forEach(cb => {
            cb.addEventListener('change', () => {
                if (!entry._introPreviewPlaying) return;
                const stem = cb.dataset.stem;
                const ws = entry.stemWs?.[stem];
                if (!ws) return;
                if (cb.checked) {
                    const d = ws.getDuration();
                    const first = entry.stemWs[Object.keys(entry.stemWs).find(k => entry.stemWs[k].isPlaying())];
                    const t = first ? first.getCurrentTime() : (entry.region.start || 0);
                    try { ws.seekTo(d > 0 ? Math.min(0.999, t / d) : 0); ws.play(); } catch {}
                } else {
                    try { ws.pause(); } catch {}
                }
            });
        });
    }

    function removeTrack(idx, card) {
        const entry = tracks.find(t => t.idx === idx);
        if (entry) {
            if (entry.pollTimer) clearInterval(entry.pollTimer);
            if (entry._introPreviewTimer) clearInterval(entry._introPreviewTimer);
            if (entry.ws) entry.ws.destroy();
            if (entry.stemWs) Object.values(entry.stemWs).forEach(w => w.destroy());
        }
        const i = tracks.findIndex(t => t.idx === idx);
        if (i >= 0) tracks.splice(i, 1);
        card.remove();
        updateCounter();
        // Re-number
        document.querySelectorAll('.track-card').forEach((c, n) => {
            c.querySelector('.track-number').textContent = `#${n + 1}`;
        });
    }

    // --- Generate ---
    async function generateTrack(idx, card) {
        const entry = tracks.find(t => t.idx === idx);
        if (!entry || !entry.trackId) return;

        const bars = card.querySelector('.track-bars:checked')?.value || '8';
        const loop = card.querySelector('.track-loop').checked;
        const introOnly = card.querySelector('.track-output:checked')?.value === 'intro';
        const genre = card.querySelector('.track-genre').value;
        const transition = card.querySelector('.track-transition')?.value || 'crossfade';
        const transitionBars = card.querySelector('.track-transition-bars')?.value || '2';

        // Get selected stems
        const selectedStems = [];
        card.querySelectorAll('.track-stem-check:checked').forEach(cb => selectedStems.push(cb.dataset.stem));
        const stemsParam = selectedStems.length > 0 ? selectedStems.join(',') : 'drums,bass,other';

        // Song start point (null = from beginning)
        const songStart = entry.songStart;
        const skipOriginalIntro = songStart != null;

        let url = `${API}/${entry.trackId}/generate-intro?bars=${bars}&loop=${loop}&introOnly=${introOnly}&mode=groove&skipOriginalIntro=${skipOriginalIntro}&stems=${stemsParam}`;
        if (genre) url += `&genre=${encodeURIComponent(genre)}`;
        if (entry.region && entry.region.start != null) url += `&regionStart=${entry.region.start.toFixed(3)}`;
        if (entry.region && entry.region.end != null) url += `&regionEnd=${entry.region.end.toFixed(3)}`;
        if (songStart != null) url += `&songStart=${songStart.toFixed(3)}`;
        url += `&transition=${encodeURIComponent(transition)}&transitionBars=${transitionBars}`;

        const btn = card.querySelector('.btn-generate');
        btn.disabled = true;
        btn.textContent = 'Starting...';

        const statusArea = card.querySelector('.track-status-area');
        const statusBox = card.querySelector('[data-role="status"]');
        statusArea.classList.remove('d-none');
        statusBox.className = 'mx-status processing';
        statusBox.textContent = 'Starting...';
        card.querySelector('.track-result').classList.add('d-none');
        card.querySelector('.track-result-info').classList.add('d-none');

        try {
            const res = await fetch(url, { method: 'POST' });
            if (!res.ok) {
                let errMsg = 'Failed';
                try { const err = await res.json(); errMsg = err.error || errMsg; } catch {}
                statusBox.className = 'mx-status failed';
                statusBox.textContent = errMsg;
                btn.disabled = false;
                btn.textContent = 'Generate';
                return;
            }
            statusBox.textContent = 'Processing -- AI is removing vocals...';
            startTrackPolling(entry, card);
        } catch (err) {
            statusBox.className = 'mx-status failed';
            statusBox.textContent = 'Network error: ' + err.message;
            btn.disabled = false;
            btn.textContent = 'Generate';
        }
    }

    // --- Poll ---
    function startTrackPolling(entry, card) {
        if (entry.pollTimer) clearInterval(entry.pollTimer);
        entry.pollTimer = setInterval(() => checkTrackStatus(entry, card), 3000);
        checkTrackStatus(entry, card);
    }

    async function checkTrackStatus(entry, card) {
        try {
            const res = await fetch(`${API}/${entry.trackId}/status`);
            const data = await res.json();
            const statusBox = card.querySelector('[data-role="status"]');
            const btn = card.querySelector('.btn-generate');

            if (data.ready) {
                clearInterval(entry.pollTimer);
                statusBox.className = 'mx-status completed';
                statusBox.textContent = data.message;

                card.querySelector('.track-bpm').textContent = data.detectedBpm ? Math.round(data.detectedBpm) : '--';
                card.querySelector('.track-det-genre').textContent = data.detectedGenre || '--';
                card.querySelector('.track-key').textContent = data.detectedKey || '--';
                card.querySelector('.track-result-info').classList.remove('d-none');

                const downloadUrl = `${API}/${entry.trackId}/download`;
                card.querySelector('.track-result-player').src = downloadUrl;
                card.querySelector('.track-download').href = downloadUrl;
                card.querySelector('.track-result').classList.remove('d-none');

                btn.disabled = false;
                btn.textContent = 'Re-generate';

            } else if (data.status === 'Failed') {
                clearInterval(entry.pollTimer);
                statusBox.className = 'mx-status failed';
                statusBox.textContent = (data.message || 'Failed');
                btn.disabled = false;
                btn.textContent = 'Generate';

            } else if (data.status === 'Queued') {
                statusBox.className = 'mx-status queued';
                statusBox.textContent = (data.message || 'In queue...');

            } else {
                statusBox.className = 'mx-status processing';
                statusBox.textContent = (data.message || 'Processing...');
            }
        } catch (err) { }
    }
</script>
}


